            <div className="text-xs text-stone-500 mt-1">{profile.offerings.length}/3 picked.</div>
          </div>

          <div className="mt-6 flex items-center gap-3">
            <button
              disabled={!ready}
              onClick={props.onDone}
              className={
                'text-sm font-medium px-4 py-2 rounded-md transition-colors ' +
                (ready ? 'text-white bg-[#C2410C] hover:bg-[#9A330A]' : 'text-stone-400 bg-stone-100 cursor-not-allowed')
              }
            >
              See my matches →
            </button>
            <span className="text-xs text-stone-500">Sector + region + at least one challenge or offering required.</span>
          </div>
        </Card>
      );
    }

    // A small label-and-input wrapper.
    function Field(props) {
      return (
        <label className="block">
          <SectionLabel>{props.label}</SectionLabel>
          {props.children}
        </label>
      );
    }


    /* ---- 8c. FindMentors ---------------------------------------
       What this section does:
         Specifically surfaces companies that have ALREADY solved a
         problem the founder is currently working on. The score is
         not "synergy" — it\'s "depth of overlap with your challenges".
         Each card shows a "What you can learn here" rationale.

       What the user sees:
         - If onboarding isn\'t done, a nudge to fill it in.
         - Otherwise: a list of mentor candidates with a clear "they
           have already solved X" rationale and a button to open the
           Connection Playbook.

       Data it uses:
         - userProfile.challenges
         - PORTFOLIO_COMPANIES (matched on .expertise)
       ------------------------------------------------------------ */
    function FindMentors(props) {
      const profile = props.userProfile;

      const candidates = React.useMemo(function () {
        if (!profile || !profile.challenges || !profile.challenges.length) return [];
        return mentorCandidates(profile, PORTFOLIO_COMPANIES);
      }, [profile]);

      const isShortlisted = function (id) {
        return props.shortlist.some(function (s) { return s.companyId === id; });
      };

      return (
        <div className="space-y-6">
          <header>
            <h2 className="font-display text-3xl text-[#0F1A2E]">Find mentors</h2>
            <p className="text-[#5A6478] mt-1 max-w-3xl">
              Match with portfolio companies that have already publicly tackled the problems you\'re working on right now.
              The "Why" isn\'t a black-box score — it\'s a specific match between your challenges and their expertise.
            </p>
          </header>

          {!profile || !profile.challenges || !profile.challenges.length ? (
            <Card className="p-8 text-center">
              <p className="text-[#0F1A2E] font-medium">First, tell us your top 3 growth challenges.</p>
              <p className="text-sm text-[#5A6478] mt-1">Open <span className="font-medium">Find collaborators</span> and fill in the short profile. We\'ll use the same answers here.</p>
            </Card>
