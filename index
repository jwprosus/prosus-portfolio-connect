                        <div>
                          <div className="flex items-center gap-2 flex-wrap">
                            <h3 className="font-display text-xl text-[#0F1A2E]">{m.company.name}</h3>
                            <Badge tone="navy">{m.company.sector}</Badge>
                            <Badge tone="neutral">{m.company.region}</Badge>
                          </div>
                          <p className="text-sm text-[#5A6478] mt-1">{m.company.description}</p>
                        </div>
                        <Badge tone="accent">Mentor — {m.score} of your challenges overlap</Badge>
                      </div>

                      <div className="mt-4 bg-amber-50/50 border border-amber-100 rounded-lg p-3">
                        <SectionLabel>What you can learn here</SectionLabel>
                        <ul className="space-y-1">
