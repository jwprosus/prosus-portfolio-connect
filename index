    /* ---- 8a. PortfolioMap --------------------------------------
       What this section does:
         Shows every non-edtech Prosus / Naspers-linked company in a
         filterable card grid. The founder can browse by sector,
         region, stage, and business model.

       What the user sees:
         - A row of filter chips at the top.
         - A search box to find a company by name.
         - A grid of company cards, each with description, founders,
           public metrics, and source citations.
         - A "Save to shortlist" / "Get connection playbook" pair of
           buttons on every card.

       Data it uses:
         - PORTFOLIO_COMPANIES (the data block above).
         - the user\'s shortlist (passed in as a prop).
       ------------------------------------------------------------ */
    function PortfolioMap(props) {
      // What the user has typed into the search box.
      const [query, setQuery] = React.useState('');
      // Which sector / region / stage / model is selected ('' means all).
      const [sector, setSector] = React.useState('');
      const [region, setRegion] = React.useState('');
      const [stage, setStage] = React.useState('');
      const [model, setModel] = React.useState('');

      // Run the filters. useMemo means we only re-run when inputs change.
      const filtered = React.useMemo(function () {
        return PORTFOLIO_COMPANIES.filter(function (c) {
          if (sector && c.sector !== sector) return false;
          if (region && c.region !== region) return false;
          if (stage && c.stage !== stage) return false;
          if (model && c.businessModel !== model) return false;
          if (query) {
            const q = query.toLowerCase();
            const haystack = (c.name + ' ' + c.description + ' ' + c.founders.join(' ') + ' ' + c.hq).toLowerCase();
            if (haystack.indexOf(q) === -1) return false;
          }
          return true;
        });
      }, [query, sector, region, stage, model]);

      const isShortlisted = function (id) {
        return props.shortlist.some(function (s) { return s.companyId === id; });
      };

      return (
        <div className="space-y-6">
          <header>
            <h2 className="font-display text-3xl text-[#0F1A2E]">Portfolio Map</h2>
            <p className="text-[#5A6478] mt-1 max-w-3xl">
