              metrics, founder names where they\'re published, and the news / LinkedIn links we used. Re-verify the
              "last verified" dates if anything looks off.
            </p>
          </header>

          {/* Filters */}
          <Card className="p-4">
            <div className="flex flex-wrap gap-3">
              <input
                value={query}
                onChange={function (e) { setQuery(e.target.value); }}
                placeholder="Search company, founder, HQ…"
                className="flex-1 min-w-[200px] px-3 py-2 border border-[#E8E2D5] rounded-md text-sm bg-white focus:outline-none focus:border-[#C2410C]"
              />
              <FilterSelect label="Sector" value={sector} options={SECTORS} onChange={setSector} />
              <FilterSelect label="Region" value={region} options={REGIONS} onChange={setRegion} />
              <FilterSelect label="Stage" value={stage} options={STAGES} onChange={setStage} />
              <FilterSelect label="Model" value={model} options={BUSINESS_MODELS} onChange={setModel} />
              {(query || sector || region || stage || model) ? (
                <button
                  onClick={function () { setQuery(''); setSector(''); setRegion(''); setStage(''); setModel(''); }}
                  className="text-sm text-stone-600 hover:text-[#C2410C] underline decoration-dotted underline-offset-4"
                >
                  Reset
                </button>
              ) : null}
            </div>
            <div className="text-xs text-stone-500 mt-2">
              Showing <span className="font-semibold text-[#0F1A2E]">{filtered.length}</span> of {PORTFOLIO_COMPANIES.length} companies. Edtech is intentionally excluded.
            </div>
          </Card>

          {/* Grid */}
          <div className="grid grid-cols-1 lg:grid-cols-2 gap-5">
            {filtered.map(function (c) {
              return (
                <CompanyCard
                  key={c.id}
                  company={c}
                  isShortlisted={isShortlisted(c.id)}
                  onAddToShortlist={props.addToShortlist}
                  onRemoveFromShortlist={props.removeFromShortlist}
                  onOpenPlaybook={props.openPlaybook}
                />
              );
