        </div>
      );
    }


    /* ---- 8d. ConnectionPlaybook --------------------------------
       What this section does:
         Generates an editable warm-intro template (routed via the
         user\'s Prosus partner, not cold), three tailored talking
         points, and three suggested first-call questions for any
         portfolio company.

       What the user sees:
         - A company picker (defaults to whatever they clicked).
         - The match summary (score + reasons).
         - Editable email text inside a big text-area.
         - A "Copy to clipboard" button.
         - The talking points and first-call questions.

       Data it uses:
         - userProfile (for personalising the template).
         - PORTFOLIO_COMPANIES (the candidate companies).
         - INTRO_TEMPLATES (the editable email templates).
       ------------------------------------------------------------ */
    function ConnectionPlaybook(props) {
      const profile = props.userProfile;
      // Local state: which company has the user picked?
      const [companyId, setCompanyId] = React.useState(props.preselectedCompanyId || PORTFOLIO_COMPANIES[0].id);

      // If the parent says to preselect a different company, follow it.
      React.useEffect(function () {
        if (props.preselectedCompanyId && props.preselectedCompanyId !== companyId) {
          setCompanyId(props.preselectedCompanyId);
        }
      }, [props.preselectedCompanyId]);

      const company = lookupCompany(companyId);
      const playbook = React.useMemo(function () {
        if (!company || !profile) return null;
        return generatePlaybook(profile, company);
      }, [company, profile]);

      // Local editable state for the intro email so the user can edit it.
      const [emailDraft, setEmailDraft] = React.useState('');
      React.useEffect(function () {
        if (playbook) setEmailDraft(playbook.email);
      }, [playbook ? playbook.email : null]);

      const [copied, setCopied] = React.useState(false);
      const copy = function () {
        try {
          navigator.clipboard.writeText(emailDraft);
          setCopied(true);
          setTimeout(function () { setCopied(false); }, 1800);
        } catch (e) {
          // Clipboard not available — show a visible reminder.
          setCopied(false);
        }
      };

      const ready = profile && profile.sector && (profile.challenges.length > 0 || profile.offerings.length > 0);

      return (
        <div className="space-y-6">
          <header>
            <h2 className="font-display text-3xl text-[#0F1A2E]">Connection playbook</h2>
            <p className="text-[#5A6478] mt-1 max-w-3xl">
              Pick a company, get an editable warm-intro you can route via your Prosus partner (not cold), three talking
              points specific to your overlap, and a starter set of first-call questions.
            </p>
          </header>

          {!ready ? (
            <Card className="p-8 text-center">
              <p className="text-[#0F1A2E] font-medium">First, fill in the short profile in <span className="text-[#C2410C]">Find collaborators</span>.</p>
              <p className="text-sm text-[#5A6478] mt-1">It powers the personalisation here.</p>
            </Card>
          ) : (
            <React.Fragment>
              <Card className="p-5">
                <div className="flex flex-wrap items-center gap-3">
                  <label className="text-sm text-stone-600">Pick a company:</label>
                  <select
                    value={companyId}
                    onChange={function (e) { setCompanyId(e.target.value); }}
                    className="px-3 py-2 border border-[#E8E2D5] rounded-md text-sm bg-white focus:outline-none focus:border-[#C2410C]"
                  >
                    {PORTFOLIO_COMPANIES.map(function (c) {
                      return <option key={c.id} value={c.id}>{c.name} · {c.sector}</option>;
                    })}
                  </select>
                </div>
              </Card>

              {company && playbook ? (
                <div className="grid grid-cols-1 lg:grid-cols-3 gap-5">
                  {/* LEFT: company snapshot + match */}
                  <Card className="p-5 lg:col-span-1 self-start">
                    <SectionLabel>Target</SectionLabel>
                    <h3 className="font-display text-xl text-[#0F1A2E]">{company.name}</h3>
                    <div className="flex flex-wrap gap-1.5 mt-1">
                      <Badge tone="navy">{company.sector}</Badge>
                      <Badge tone="neutral">{company.region}</Badge>
                    </div>
                    <p className="text-sm text-[#5A6478] mt-2">{company.description}</p>

                    <div className="mt-4">
                      <SectionLabel>Synergy</SectionLabel>
                      <div className="flex items-baseline gap-2">
                        <div className="font-display text-3xl text-[#C2410C] leading-none">{playbook.match.score}</div>
                        <Badge tone="accent">{playbook.match.primaryType}</Badge>
                      </div>
                    </div>

                    {playbook.match.rationales.length ? (
                      <div className="mt-3">
                        <SectionLabel>Why this works</SectionLabel>
                        <ul className="space-y-1.5">
                          {playbook.match.rationales.map(function (r, i) {
                            return (
                              <li key={i} className="text-sm text-[#0F1A2E]">
                                <span className="font-medium">{r.type}:</span>{' '}
                                <span className="text-[#5A6478]">{r.label}</span>
                              </li>
                            );
                          })}
                        </ul>
                      </div>
                    ) : null}

                    <SourceList sources={company.sources} />
                  </Card>

                  {/* RIGHT: editable email + talking points */}
                  <div className="lg:col-span-2 space-y-5">
                    <Card className="p-5">
                      <div className="flex items-center justify-between gap-2 flex-wrap">
                        <SectionLabel>Warm-intro email (route via your Prosus partner)</SectionLabel>
                        <button
                          onClick={copy}
                          className="text-xs font-medium text-[#0F1A2E] bg-white border border-[#0F1A2E]/15 hover:border-[#0F1A2E]/40 px-2.5 py-1 rounded-md"
                        >
                          {copied ? 'Copied!' : 'Copy to clipboard'}
                        </button>
                      </div>
                      <textarea
                        value={emailDraft}
                        onChange={function (e) { setEmailDraft(e.target.value); }}
                        rows={14}
                        className="mt-2 w-full px-3 py-2 border border-[#E8E2D5] rounded-md text-sm bg-white focus:outline-none focus:border-[#C2410C] font-mono"
                      />
                      <p className="text-xs text-stone-500 mt-2">
                        Tip: keep it short. Edit the [Prosus partner] placeholder before sending. We don\'t store partner names because we don\'t know yours.
                      </p>
                    </Card>

                    <div className="grid grid-cols-1 md:grid-cols-2 gap-5">
                      <Card className="p-5">
                        <SectionLabel>Three tailored talking points</SectionLabel>
                        <ol className="list-decimal pl-5 space-y-2 text-sm text-[#0F1A2E]">
                          {playbook.talkingPoints.map(function (t, i) { return <li key={i}>{t}</li>; })}
                        </ol>
                      </Card>
                      <Card className="p-5">
                        <SectionLabel>First-call questions</SectionLabel>
                        <ol className="list-decimal pl-5 space-y-2 text-sm text-[#0F1A2E]">
                          {playbook.questions.map(function (q, i) { return <li key={i}>{q}</li>; })}
                        </ol>
                      </Card>
                    </div>
                  </div>
                </div>
              ) : null}
            </React.Fragment>
          )}
        </div>
      );
    }


    /* ---- 8e. KnowledgeFeed -------------------------------------
       What this section does:
         A curated feed of public content from non-edtech Prosus
         portfolio founders — interviews, podcasts, conference
         talks, news pieces — each tagged so the founder can filter
         by their own challenges.

       What the user sees:
         - A row of topic chips and a "matches my challenges" toggle.
         - A list of items, each with title, source, person/company,
           a short summary, and a link to the original.

       Data it uses:
         - KNOWLEDGE_ITEMS.
         - userProfile.challenges (for the personalisation toggle).
       ------------------------------------------------------------ */
    function KnowledgeFeed(props) {
      const profile = props.userProfile;
      const userTags = (profile && profile.challenges) || [];

      const [topicFilter, setTopicFilter] = React.useState('');
      const [matchMine, setMatchMine] = React.useState(false);
      const [sourceTypeFilter, setSourceTypeFilter] = React.useState('');

      // All unique tags / source types in the feed (for chip rows).
      const allTags = React.useMemo(function () {
        const set = {};
        KNOWLEDGE_ITEMS.forEach(function (k) {
          k.topics.forEach(function (t) { set[t] = true; });
        });
        return Object.keys(set);
      }, []);
      const allSourceTypes = React.useMemo(function () {
        const set = {};
        KNOWLEDGE_ITEMS.forEach(function (k) { set[k.sourceType] = true; });
        return Object.keys(set);
      }, []);

      // Filter + rank.
      const items = React.useMemo(function () {
        let out = KNOWLEDGE_ITEMS.slice();
        if (topicFilter) out = out.filter(function (k) { return k.topics.indexOf(topicFilter) !== -1; });
        if (sourceTypeFilter) out = out.filter(function (k) { return k.sourceType === sourceTypeFilter; });
        if (matchMine && userTags.length) {
          out = out.filter(function (k) {
            return k.topics.some(function (t) { return userTags.indexOf(t) !== -1; });
          });
        }
        // When matchMine is on, sort by overlap descending; else by date desc.
        if (matchMine && userTags.length) {
          out.sort(function (a, b) {
            const oa = a.topics.filter(function (t) { return userTags.indexOf(t) !== -1; }).length;
            const ob = b.topics.filter(function (t) { return userTags.indexOf(t) !== -1; }).length;
            return ob - oa;
          });
        } else {
          out.sort(function (a, b) { return (b.publishedDate || '').localeCompare(a.publishedDate || ''); });
        }
        return out;
      }, [topicFilter, sourceTypeFilter, matchMine, userTags.join('|')]);

      return (
        <div className="space-y-6">
          <header>
            <h2 className="font-display text-3xl text-[#0F1A2E]">Knowledge feed</h2>
            <p className="text-[#5A6478] mt-1 max-w-3xl">
              Public commentary from non-edtech Prosus founders — interviews, podcasts, conference talks, and news.
              Filter by topic, or toggle "Matches my challenges" once you\'ve filled in your profile.
            </p>
          </header>

          <Card className="p-4">
            <div className="flex flex-wrap items-center gap-3">
              <label className="flex items-center gap-2 text-sm">
                <input
                  type="checkbox"
                  checked={matchMine}
                  disabled={!userTags.length}
                  onChange={function (e) { setMatchMine(e.target.checked); }}
                  className="accent-[#C2410C]"
                />
                <span className={!userTags.length ? 'text-stone-400' : 'text-[#0F1A2E]'}>
                  Matches my challenges
                  {!userTags.length ? <span className="text-stone-400"> (set your profile first)</span> : null}
                </span>
              </label>
              <FilterSelect label="Topic" value={topicFilter} options={allTags.map(function (t) { return t; })} onChange={setTopicFilter} />
              <FilterSelect label="Source type" value={sourceTypeFilter} options={allSourceTypes} onChange={setSourceTypeFilter} />
              {(topicFilter || sourceTypeFilter || matchMine) ? (
                <button
                  onClick={function () { setTopicFilter(''); setSourceTypeFilter(''); setMatchMine(false); }}
                  className="text-sm text-stone-600 hover:text-[#C2410C] underline decoration-dotted underline-offset-4"
                >
                  Reset
                </button>
              ) : null}
            </div>
          </Card>

          <div className="space-y-3">
            {items.map(function (k) {
              const userOverlap = userTags.length
                ? k.topics.filter(function (t) { return userTags.indexOf(t) !== -1; })
                : [];
              return (
                <Card key={k.id} className="p-5 fade-in">
                  <div className="flex items-start justify-between gap-3 flex-wrap">
                    <div>
                      <div className="text-xs uppercase tracking-wider text-stone-500 mb-1">
                        {k.sourceType} · {k.sourceName} · {k.publishedDate}
                      </div>
                      <h3 className="font-display text-lg text-[#0F1A2E] leading-snug">
                        {k.url ? (
                          <a href={k.url} target="_blank" rel="noopener noreferrer" className="hover:text-[#C2410C]">
                            {k.title}
                          </a>
                        ) : k.title}
                      </h3>
                      <div className="text-sm text-[#5A6478] mt-1">
                        <span className="font-medium text-[#0F1A2E]">{k.person}</span> · {k.company}
                      </div>
                      <p className="text-sm text-[#0F1A2E] mt-2 leading-relaxed">{k.summary}</p>
                    </div>
                    <div className="text-right shrink-0">
                      {userOverlap.length ? (
                        <Badge tone="accent">{userOverlap.length} of your challenges</Badge>
                      ) : null}
                    </div>
                  </div>

                  <div className="mt-3 flex flex-wrap gap-1.5">
                    {k.topics.map(function (t) {
                      return <Badge key={t} tone={userOverlap.indexOf(t) !== -1 ? 'accent' : 'neutral'}>{labelForTag(t)}</Badge>;
                    })}
                  </div>

                  <div className="mt-3 text-xs text-stone-500">
                    {k.url ? (
                      <a href={k.url} target="_blank" rel="noopener noreferrer" className="underline decoration-stone-300 hover:decoration-orange-400">
                        Visit {k.sourceName} →
                      </a>
                    ) : null}
                    <span className="text-stone-400"> · last verified {k.verified}</span>
                  </div>
                </Card>
              );
            })}

            {!items.length ? (
              <Card className="p-10 text-center text-[#5A6478]">
                No items match those filters.
              </Card>
            ) : null}
          </div>
        </div>
      );
    }


    /* ---- 8f. MyShortlist ---------------------------------------
       What this section does:
         The founder\'s pinned list. They can mark each entry with a
         status (Want to meet / Reached out / Connected / Working
         together) and add a short note.

       What the user sees:
         - A list of saved companies.
         - Each row has a status drop-down, a free-text note, and a
           remove button.

       Data it uses:
         - shortlist (lifted state in App).
         - PORTFOLIO_COMPANIES.
       ------------------------------------------------------------ */
    function MyShortlist(props) {
      const list = props.shortlist;

      const STATUSES = ['Want to meet', 'Reached out', 'Connected', 'Working together'];

      return (
        <div className="space-y-6">
          <header>
            <h2 className="font-display text-3xl text-[#0F1A2E]">My shortlist</h2>
            <p className="text-[#5A6478] mt-1 max-w-3xl">
              Companies you\'ve pinned. Tag each with where you are — "Want to meet" → "Working together" — and
              jot down notes from your calls. Lives in this browser tab only; closing it will reset (no
              accounts, no servers, by design).
            </p>
          </header>

          {!list.length ? (
            <Card className="p-10 text-center text-[#5A6478]">
              <p>Nothing saved yet. Open <span className="font-medium">Portfolio Map</span> or <span className="font-medium">Find collaborators</span> and tap "Save to shortlist" on any company.</p>
            </Card>
          ) : (
            <div className="space-y-3">
              {list.map(function (entry) {
                const c = lookupCompany(entry.companyId);
                if (!c) return null;
                return (
                  <Card key={entry.companyId} className="p-5 fade-in">
                    <div className="flex flex-wrap items-start justify-between gap-3">
                      <div>
                        <div className="flex items-center gap-2 flex-wrap">
                          <h3 className="font-display text-lg text-[#0F1A2E]">{c.name}</h3>
                          <Badge tone="navy">{c.sector}</Badge>
                          <Badge tone="neutral">{c.region}</Badge>
                        </div>
                        <p className="text-sm text-[#5A6478] mt-1">{c.description}</p>
                      </div>
                      <div className="flex items-center gap-2">
                        <select
                          value={entry.status || 'Want to meet'}
                          onChange={function (e) { props.updateShortlistEntry(entry.companyId, { status: e.target.value }); }}
                          className="px-3 py-1.5 border border-[#E8E2D5] rounded-md text-sm bg-white focus:outline-none focus:border-[#C2410C]"
                        >
                          {STATUSES.map(function (s) { return <option key={s} value={s}>{s}</option>; })}
                        </select>
                        <button
                          onClick={function () { props.removeFromShortlist(entry.companyId); }}
                          className="text-sm text-stone-700 bg-stone-100 hover:bg-stone-200 px-3 py-1.5 rounded-md"
                        >
                          Remove
                        </button>
                      </div>
                    </div>
                    <div className="mt-3">
                      <SectionLabel>Notes</SectionLabel>
                      <textarea
                        rows={3}
                        value={entry.notes || ''}
                        onChange={function (e) { props.updateShortlistEntry(entry.companyId, { notes: e.target.value }); }}
                        placeholder="Who you spoke to, what they suggested, next step…"
                        className="w-full px-3 py-2 border border-[#E8E2D5] rounded-md text-sm bg-white focus:outline-none focus:border-[#C2410C]"
                      />
                    </div>
                    <div className="mt-3">
                      <button
                        onClick={function () { props.openPlaybook(entry.companyId); }}
                        className="text-sm font-medium text-[#C2410C] hover:text-[#9A330A] underline decoration-dotted underline-offset-4"
                      >
                        Open connection playbook →
                      </button>
                    </div>
                  </Card>
                );
              })}
            </div>
          )}
        </div>
      );
    }


    /* ============================================================
       === 9. HEADER & FOOTER ====================================
       ============================================================ */

    function Header(props) {
      return (
        <header className="border-b border-[#E8E2D5] bg-[#FAF7F2]/80 backdrop-blur sticky top-0 z-20">
          <div className="max-w-6xl mx-auto px-5 py-4 flex flex-wrap items-center gap-3 justify-between">
            <div className="flex items-baseline gap-3">
              <span className="font-display text-xl text-[#0F1A2E] tracking-tight">Prosus Portfolio Connect</span>
              <span className="hidden md:inline text-xs text-stone-500">A founder-built tool · public info only</span>
            </div>
            <nav className="flex flex-wrap gap-1 -mx-1 overflow-x-auto scrollbar-thin">
              {props.sections.map(function (s, i) {
                const isActive = s.id === props.activeSectionId;
                return (
                  <button
                    key={s.id}
                    onClick={function () { props.onSelect(s.id); }}
                    className={
                      'text-sm px-3 py-1.5 rounded-md transition-colors whitespace-nowrap ' +
                      (isActive
                        ? 'bg-[#0F1A2E] text-white'
                        : 'text-[#0F1A2E] hover:bg-stone-100')
                    }
                  >
                    <span className="text-stone-400 mr-1.5">{String(i + 1).padStart(2, '0')}</span>
                    {s.name}
                  </button>
                );
              })}
            </nav>
          </div>
        </header>
      );
    }

    function Footer() {
      return (
        <footer className="border-t border-[#E8E2D5] mt-16 py-8 text-xs text-stone-500">
          <div className="max-w-6xl mx-auto px-5 space-y-2">
            <p>
              <span className="font-medium text-[#0F1A2E]">Disclaimer.</span>{' '}
              Independent founder-built tool. Not affiliated with, endorsed by, or operated on behalf of Prosus N.V., Naspers Limited, or any of their portfolio companies.
            </p>
            <p>
              All company information is drawn from publicly available sources (news outlets, company websites, LinkedIn). Re-verify "last verified" dates before acting on anything material.
              Metrics labelled <span className="text-orange-700">illustrative</span> were inferred from public commentary and should not be cited as fact.
            </p>
            <p>No founder emails or internal Prosus partner names are stored or generated by this tool. Warm intros must be routed via your own Prosus relationship.</p>
          </div>
        </footer>
      );
    }


    /* ============================================================
       === 10. SECTIONS REGISTRY =================================
       ============================================================
       This is the master list of features. The header navigation
       and the main content area both read from it.

       --- TO REMOVE A FEATURE ---
       Delete (or comment out) the line for the feature you don\'t
       want. The menu item AND the screen vanish.

       --- TO RE-ORDER ---
       Re-arrange the lines. The header pills and default landing
       section both follow this order.

       --- TO ADD A NEW FEATURE ---
       1. Write a new component (copy one of the existing ones).
       2. Add a line to this array with { id, name, Component }.
       The id MUST be unique.
       ------------------------------------------------------------ */

    const SECTIONS = [
      { id: 'portfolio',     name: 'Portfolio Map',       Component: PortfolioMap },
      { id: 'collaborators', name: 'Find collaborators',  Component: FindCollaborators },
      { id: 'mentors',       name: 'Find mentors',        Component: FindMentors },
      { id: 'playbook',      name: 'Connection playbook', Component: ConnectionPlaybook },
      { id: 'knowledge',     name: 'Knowledge feed',      Component: KnowledgeFeed },
      { id: 'shortlist',     name: 'My shortlist',        Component: MyShortlist },
    ];


    /* ============================================================
       === 11. APP ===============================================
       ============================================================
       The root component. It owns the shared state (user profile,
       shortlist, which section is active) and renders:
         - the header,
         - the active section,
         - the footer.

       Each section gets exactly the slice of state it needs.
       ------------------------------------------------------------ */

    function App() {
      // Which feature screen is currently visible.
      const [activeSectionId, setActiveSectionId] = React.useState(SECTIONS[0].id);

      // The founder\'s onboarding answers (used by collaborators / mentors / playbook).
      // Lives in component state only — disappears when the tab is closed (per spec).
      const [userProfile, setUserProfile] = React.useState({
        founderName: '',
        companyName: '',
        sector: '',
        region: '',
        expandTo: '',
        customerType: '',
        gtmMotion: '',
        challenges: [],   // up to 3 tags from CHALLENGE_OPTIONS
        offerings: [],    // up to 3 tags from OFFERING_OPTIONS
      });

      // The shortlist — array of { companyId, status, notes }.
      const [shortlist, setShortlist] = React.useState([]);

      // The currently-selected playbook target (set when user clicks
      // "Get connection playbook" anywhere in the app).
      const [playbookCompanyId, setPlaybookCompanyId] = React.useState(null);

      // -- shortlist helpers --
      const addToShortlist = function (companyId) {
        setShortlist(function (prev) {
          if (prev.some(function (s) { return s.companyId === companyId; })) return prev;
          return prev.concat([{ companyId: companyId, status: 'Want to meet', notes: '' }]);
        });
      };
      const removeFromShortlist = function (companyId) {
        setShortlist(function (prev) { return prev.filter(function (s) { return s.companyId !== companyId; }); });
      };
      const updateShortlistEntry = function (companyId, partial) {
        setShortlist(function (prev) {
          return prev.map(function (s) {
            if (s.companyId !== companyId) return s;
            return Object.assign({}, s, partial);
          });
        });
      };

      // Open the playbook section for a particular company.
      const openPlaybook = function (companyId) {
        setPlaybookCompanyId(companyId);
        setActiveSectionId('playbook');
        // Scroll to top — friendlier on long lists.
        if (typeof window !== 'undefined') window.scrollTo({ top: 0, behavior: 'smooth' });
      };

      // Find the active section\'s component.
      const activeSection = SECTIONS.find(function (s) { return s.id === activeSectionId; }) || SECTIONS[0];
      const ActiveComponent = activeSection.Component;

      return (
        <div className="min-h-screen bg-[#FAF7F2] text-[#0F1A2E]">
          <Header
            sections={SECTIONS}
            activeSectionId={activeSectionId}
            onSelect={function (id) { setActiveSectionId(id); if (typeof window !== 'undefined') window.scrollTo({ top: 0, behavior: 'smooth' }); }}
          />

          <main className="max-w-6xl mx-auto px-5 py-8">
            <ActiveComponent
              userProfile={userProfile}
              setUserProfile={setUserProfile}
              shortlist={shortlist}
              addToShortlist={addToShortlist}
              removeFromShortlist={removeFromShortlist}
              updateShortlistEntry={updateShortlistEntry}
              openPlaybook={openPlaybook}
              preselectedCompanyId={playbookCompanyId}
            />
          </main>

          <Footer />
        </div>
      );
    }


    // Mount the App into the page.
    const rootEl = document.getElementById('root');
    const root = ReactDOM.createRoot(rootEl);
    root.render(<App />);
  </script>
</body>
</html>
