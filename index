    /* ============================================================
       === 6. HELPER FUNCTIONS ===================================
       ============================================================
       Pure functions that turn DATA into MATCHES.
       Each function is heavily commented so a non-coder can read
       through the logic step by step.
       ------------------------------------------------------------ */

    /**
     * lookupCompany
     * --------------
     * Given a company id, return the full company object.
     * Used everywhere we have just the id and need details.
     */
    function lookupCompany(id) {
      return PORTFOLIO_COMPANIES.find(function (c) { return c.id === id; }) || null;
    }

    /**
     * intersectTags
     * --------------
     * Given two arrays of tag strings, return the values that appear
     * in BOTH. Used to find shared topics between the user and a
     * portfolio company.
     */
    function intersectTags(a, b) {
      if (!a || !b) return [];
      return a.filter(function (tag) { return b.indexOf(tag) !== -1; });
    }

    /**
     * labelForTag
     * --------------
     * Tags are short codes (like 'last-mile-logistics'). The user
     * shouldn\'t see those — they should see the friendly label
     * (like 'Last-mile logistics & delivery ops'). This function
     * looks up the friendly label, falling back to the tag itself.
     */
    function labelForTag(tag) {
      const fromChallenge = CHALLENGE_OPTIONS.find(function (o) { return o.tag === tag; });
      if (fromChallenge) return fromChallenge.label;
      const fromOffering = OFFERING_OPTIONS.find(function (o) { return o.tag === tag; });
      if (fromOffering) return fromOffering.label;
      return tag;
    }

    /**
     * scoreCompanyForUser
     * --------------------
     * Step 1: How much overlap is there between the user\'s growth
     *         CHALLENGES and the company\'s EXPERTISE? (mentor angle)
     * Step 2: How much overlap is there between the user\'s OFFERINGS
     *         and the company\'s NEEDS? (partner angle)
     * Step 3: Are they in the same region? (geographic angle)
     * Step 4: Does the user sell B2B and the company is in a sector
     *         that often buys their kind of product? (customer fit)
     *
     * We then add the points up to a "Synergy Score" between 0 and 100
     * (capped). We also collect human-readable RATIONALES so the UI
     * can show "WHY" the match exists — never a black-box score.
     *
     * Returns:
     *   {
     *     score: number,
     *     rationales: [{type, label, tags}],
     *     primaryType: 'Customer fit' | 'Distribution partner' | ...
     *   }
     */
    function scoreCompanyForUser(user, company) {
      const rationales = [];

      // --- mentor / learning overlap ---
      const challengeOverlap = intersectTags(user.challenges, company.expertise);
      const mentorPoints = challengeOverlap.length * 18;
      if (challengeOverlap.length) {
        rationales.push({
          type: 'Mentor',
          label: 'Has solved problems you\'re working on',
          tags: challengeOverlap,
          points: mentorPoints,
        });
      }

      // --- partner: my offerings cover their needs ---
      const offerNeedOverlap = intersectTags(user.offerings, company.needs);
      const partnerPoints = offerNeedOverlap.length * 22;
      if (offerNeedOverlap.length) {
        rationales.push({
          type: 'Tech or data partner',
          label: 'Could benefit from what you offer',
          tags: offerNeedOverlap,
          points: partnerPoints,
        });
      }

      // --- partner: their expertise covers my offerings (distribution) ---
      // This catches cases where the COMPANY can distribute / scale FOR
      // the user (e.g. user offers a B2B product, company has a relevant
      // customer base or geographic reach).
      const distOverlap = intersectTags(user.offerings, company.expertise);
      const distPoints = distOverlap.length * 14;
      if (distOverlap.length) {
        rationales.push({
          type: 'Distribution partner',
          label: 'Has the reach you can build on',
          tags: distOverlap,
          points: distPoints,
        });
      }

      // --- geographic overlap ---
      let geoPoints = 0;
      if (user.region && company.region && user.region === company.region) {
        geoPoints += 8;
        rationales.push({
          type: 'Geographic expansion partner',
          label: 'Operates in your home region — peer market dynamics',
          tags: [],
          points: 8,
        });
      } else if (user.expandTo && company.region && user.expandTo === company.region) {
        geoPoints += 18;
        rationales.push({
          type: 'Geographic expansion partner',
          label: 'Operates in a region you want to expand into (' + company.region + ')',
          tags: [],
          points: 18,
        });
      }

      // --- customer fit (rough heuristic) ---
      // If the user runs a B2B business, any portfolio company can
      // plausibly be a customer or potential channel. We add a small
      // boost when their sector is one that typically buys what the
      // user offers.
      let customerPoints = 0;
      if (user.customerType === 'B2B' || user.customerType === 'B2B2C') {
        // any sector match is at least neutral; we don\'t want to be
        // noisy here, so only mark this when there\'s ALSO some other
        // signal.
        if (rationales.length > 0) {
          customerPoints = 6;
          rationales.push({
            type: 'Customer fit',
            label: company.name + ' could be a B2B customer or channel for you',
            tags: [],
            points: customerPoints,
          });
        }
      }

      // --- aggregate ---
      let total = mentorPoints + partnerPoints + distPoints + geoPoints + customerPoints;
      if (total > 100) total = 100;

      // Pick the rationale with the most points to label the match.
      let primaryType = 'Peer';
      let topPoints = -1;
      rationales.forEach(function (r) {
        if (r.points > topPoints) {
          topPoints = r.points;
          primaryType = r.type;
        }
      });

      return { score: total, rationales: rationales, primaryType: primaryType };
    }

    /**
     * filterAndScoreCompanies
     * ------------------------
     * Run scoreCompanyForUser over every portfolio company, then keep
     * only the ones that scored above zero, sorted high → low.
     */
    function filterAndScoreCompanies(user, companies) {
      return companies
        .map(function (c) {
          return Object.assign({}, c, { match: scoreCompanyForUser(user, c) });
        })
        .filter(function (c) { return c.match.score > 0; })
        .sort(function (a, b) { return b.match.score - a.match.score; });
    }

    /**
     * mentorCandidates
     * -----------------
     * Same idea but specifically for FindMentors — only surface
     * companies that overlap with the user\'s CHALLENGES (expertise
     * angle), rank by mentor strength.
     */
    function mentorCandidates(user, companies) {
      return companies
        .map(function (c) {
          const overlap = intersectTags(user.challenges, c.expertise);
          return { company: c, overlap: overlap, score: overlap.length };
        })
        .filter(function (m) { return m.score > 0; })
        .sort(function (a, b) { return b.score - a.score; });
    }

    /**
     * fillTemplate
     * --------------
     * Replace every {placeholder} in the template string with the
     * matching value from the values object. Anything not found is
     * left as-is so the user notices and edits it.
     */
    function fillTemplate(template, values) {
      return template.replace(/\{(\w+)\}/g, function (match, key) {
        if (values[key] !== undefined && values[key] !== null && values[key] !== '') {
          return values[key];
        }
        return match;
      });
    }

    /**
     * generatePlaybook
     * -----------------
     * For a given user + target company, build:
     *   - the warm intro email (filled-in template)
     *   - three tailored talking points
     *   - three suggested first-call questions
     *
     * The talking points and questions are generated from the
     * matching tags so they feel specific, not generic.
     */
    function generatePlaybook(user, company) {
      const match = scoreCompanyForUser(user, company);
      const isMentor = match.primaryType === 'Mentor';

      // Build the strongest "why" explanation in plain English.
      const mainRationale = match.rationales[0] || {
        label: 'You and ' + company.name + ' both operate in the Prosus family of high-growth consumer-internet businesses.',
        tags: [],
      };

      const sharedContext = mainRationale.label.toLowerCase().replace(/^./, function (c) { return c.toLowerCase(); });

      // Friendly labels for any matching tags.
      const sharedTags = (mainRationale.tags || []).map(labelForTag);

      // Choose the right template.
      const baseTemplate = isMentor ? INTRO_TEMPLATES.mentorIntroEmail : INTRO_TEMPLATES.warmIntroEmail;

      // Reasonable defaults for the "ask" and "offer" lines.
      const askLine = isMentor
        ? 'compare notes on how they approached the problem'
        : 'explore a concrete pilot around ' + (sharedTags[0] || 'what we both care about');
      const offerLine = (user.offerings && user.offerings.length)
        ? user.offerings.map(labelForTag).slice(0, 2).join(' and ')
        : 'introductions, market context, and a willing testbed';

      const email = fillTemplate(baseTemplate, {
        founderName: user.founderName || '[your name]',
        userCompany: user.companyName || '[your company]',
        userSector: user.sector || '[your sector]',
        targetCompany: company.name,
        targetSector: company.sector,
        targetRegion: company.region,
        matchType: match.primaryType,
        sharedContext: sharedContext,
        askLine: askLine,
        offerLine: offerLine,
      });

      // Three talking points.
      const talkingPoints = [];
      if (sharedTags.length) {
        talkingPoints.push(
          'Your shared territory: ' + sharedTags.join(', ') + '. Open with the specific question you\'ve been wrestling with.'
        );
      } else {
        talkingPoints.push(
          'You both operate inside the Prosus family of consumer-internet businesses — anchor on a concrete shared problem rather than the affiliation itself.'
        );
      }
      talkingPoints.push(
        'Acknowledge ' + company.name + '\'s market position in ' + company.region + ' (' + company.sector + ') and what specifically caught your attention recently.'
      );
      if (isMentor) {
        talkingPoints.push(
          'Make it clearly a "learn from you" call, not a sales call. End with how you might return the favour.'
        );
      } else {
        talkingPoints.push(
          'Sketch a specific 30-day pilot or working session you could run together. Not a generic partnership.'
        );
      }

      // Three first-call questions.
      const questions = [];
      if (sharedTags.length) {
        questions.push('How did your team think about ' + sharedTags[0].toLowerCase() + ' in the early days vs. now? What changed?');
        if (sharedTags[1]) {
          questions.push('On ' + sharedTags[1].toLowerCase() + ' — where did you go wrong first, and what would you do differently?');
        } else {
          questions.push('What\'s the metric you obsess over today that you would have ignored two years ago?');
        }
      } else {
        questions.push('What\'s the most non-obvious lesson from scaling ' + company.name + ' in ' + company.region + '?');
        questions.push('What\'s the metric you obsess over today that you would have ignored two years ago?');
      }
      questions.push(
        isMentor
          ? 'If we tried what you did, what would you tell us to be most cautious about?'
          : 'If we ran a 30-day pilot together, what would success look like for you?'
      );

      return {
        email: email,
        talkingPoints: talkingPoints,
        questions: questions,
        match: match,
      };
    }


