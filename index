                  );
                })}
              </div>

              {!matches.length ? (
                <Card className="p-10 text-center text-[#5A6478]">
                  No matches yet. Try adding a couple more challenges or offerings.
                </Card>
              ) : null}
            </div>
          ) : null}
        </div>
      );
    }

    // Onboarding form — used by FindCollaborators.
    function OnboardingForm(props) {
      const profile = props.profile;
      const setProfile = props.setProfile;

      // Helper to update one field at a time.
      const updateField = function (key, value) {
        setProfile(function (prev) {
          const next = Object.assign({}, prev);
          next[key] = value;
          return next;
        });
      };

      // Helper to toggle a tag in an array (max 3).
      const toggleTag = function (key, tag) {
        setProfile(function (prev) {
          const list = prev[key] || [];
          let next;
          if (list.indexOf(tag) !== -1) {
            next = list.filter(function (t) { return t !== tag; });
          } else if (list.length >= 3) {
            next = list; // already at max — ignore
          } else {
            next = list.concat(tag);
          }
          return Object.assign({}, prev, { [key]: next });
        });
      };

      const ready = profile.sector && profile.region && (profile.challenges.length > 0 || profile.offerings.length > 0);

      return (
        <Card className="p-6">
          <h3 className="font-display text-xl text-[#0F1A2E] mb-1">Tell us about you</h3>
          <p className="text-sm text-[#5A6478] mb-5">
            This stays in your browser only — nothing is sent anywhere. Skip anything you don\'t want to share.
          </p>

          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <Field label="Your name (optional)">
              <input
                value={profile.founderName || ''}
                onChange={function (e) { updateField('founderName', e.target.value); }}
                className="w-full px-3 py-2 border border-[#E8E2D5] rounded-md text-sm bg-white focus:outline-none focus:border-[#C2410C]"
                placeholder="e.g., Priya Sharma"
              />
            </Field>
            <Field label="Your company">
              <input
                value={profile.companyName || ''}
                onChange={function (e) { updateField('companyName', e.target.value); }}
                className="w-full px-3 py-2 border border-[#E8E2D5] rounded-md text-sm bg-white focus:outline-none focus:border-[#C2410C]"
                placeholder="e.g., Newco"
              />
            </Field>
            <Field label="Sector">
              <select
                value={profile.sector || ''}
                onChange={function (e) { updateField('sector', e.target.value); }}
                className="w-full px-3 py-2 border border-[#E8E2D5] rounded-md text-sm bg-white focus:outline-none focus:border-[#C2410C]"
              >
                <option value="">Pick one</option>
                {SECTORS.map(function (s) { return <option key={s} value={s}>{s}</option>; })}
              </select>
            </Field>
            <Field label="Home region">
              <select
                value={profile.region || ''}
                onChange={function (e) { updateField('region', e.target.value); }}
                className="w-full px-3 py-2 border border-[#E8E2D5] rounded-md text-sm bg-white focus:outline-none focus:border-[#C2410C]"
              >
                <option value="">Pick one</option>
                {REGIONS.map(function (r) { return <option key={r} value={r}>{r}</option>; })}
              </select>
            </Field>
            <Field label="Customer profile">
              <select
                value={profile.customerType || ''}
                onChange={function (e) { updateField('customerType', e.target.value); }}
                className="w-full px-3 py-2 border border-[#E8E2D5] rounded-md text-sm bg-white focus:outline-none focus:border-[#C2410C]"
              >
                <option value="">Pick one</option>
                {CUSTOMER_TYPES.map(function (c) { return <option key={c} value={c}>{c}</option>; })}
              </select>
            </Field>
            <Field label="Go-to-market motion">
              <select
                value={profile.gtmMotion || ''}
                onChange={function (e) { updateField('gtmMotion', e.target.value); }}
                className="w-full px-3 py-2 border border-[#E8E2D5] rounded-md text-sm bg-white focus:outline-none focus:border-[#C2410C]"
              >
                <option value="">Pick one</option>
                {GTM_MOTIONS.map(function (m) { return <option key={m} value={m}>{m}</option>; })}
              </select>
            </Field>
            <Field label="A region you'd like to expand into (optional)">
              <select
                value={profile.expandTo || ''}
                onChange={function (e) { updateField('expandTo', e.target.value); }}
                className="w-full px-3 py-2 border border-[#E8E2D5] rounded-md text-sm bg-white focus:outline-none focus:border-[#C2410C]"
              >
                <option value="">No specific region</option>
                {REGIONS.map(function (r) { return <option key={r} value={r}>{r}</option>; })}
              </select>
            </Field>
          </div>

          <div className="mt-6">
            <SectionLabel>Your top 3 growth challenges (pick up to 3)</SectionLabel>
            <div className="flex flex-wrap gap-1.5">
              {CHALLENGE_OPTIONS.map(function (opt) {
                const active = profile.challenges.indexOf(opt.tag) !== -1;
                return (
                  <button
                    key={opt.tag}
                    onClick={function () { toggleTag('challenges', opt.tag); }}
                    className={
                      'text-xs px-2.5 py-1 rounded-full border transition-colors ' +
                      (active ? 'bg-orange-100 border-orange-300 text-orange-900' : 'bg-white border-[#E8E2D5] text-stone-700 hover:border-[#C2410C]/50')
                    }
                  >
                    {opt.label}
                  </button>
                );
              })}
            </div>
            <div className="text-xs text-stone-500 mt-1">{profile.challenges.length}/3 picked.</div>
          </div>

          <div className="mt-5">
            <SectionLabel>Top 3 things you can offer others (pick up to 3)</SectionLabel>
            <div className="flex flex-wrap gap-1.5">
              {OFFERING_OPTIONS.map(function (opt) {
                const active = profile.offerings.indexOf(opt.tag) !== -1;
                return (
                  <button
                    key={opt.tag}
                    onClick={function () { toggleTag('offerings', opt.tag); }}
                    className={
                      'text-xs px-2.5 py-1 rounded-full border transition-colors ' +
                      (active ? 'bg-orange-100 border-orange-300 text-orange-900' : 'bg-white border-[#E8E2D5] text-stone-700 hover:border-[#C2410C]/50')
                    }
                  >
                    {opt.label}
                  </button>
                );
              })}
